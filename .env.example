# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=optimus
POSTGRES_PASSWORD=optimus_dev_password
POSTGRES_DB=optimus_catalog

# ── Catalog API (NestJS) ────────────────────────────────────
DATABASE_URL=postgresql://optimus:optimus_dev_password@postgres:5432/optimus_catalog?schema=public
CATALOG_PORT=3001
# Validación de tokens: issuer público (vía Traefik) + JWKS por red interna Docker
KEYCLOAK_ISSUER=http://auth.localhost/realms/optimus
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/optimus/protocol/openid-connect/certs

# ── Inventory API (NestJS) ──────────────────────────────────
INVENTORY_DATABASE_URL=postgresql://optimus:optimus_dev_password@postgres:5432/optimus_inventory?schema=public
INVENTORY_PORT=3003
INVENTORY_API_INTERNAL=http://inventory-api:3003/api

# ── Orders API (NestJS) ─────────────────────────────────────
ORDERS_DATABASE_URL=postgresql://optimus:optimus_dev_password@postgres:5432/optimus_orders?schema=public
ORDERS_PORT=3005
ORDERS_API_INTERNAL=http://orders-api:3005/api

# ── Redis (carrito) ─────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ (mensajería de eventos) ────────────────────────
RABBITMQ_USER=optimus
RABBITMQ_PASSWORD=optimus_dev_password
RABBITMQ_URL=amqp://optimus:optimus_dev_password@rabbitmq:5672

# ── Keycloak (IAM) ──────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Web (Next.js público) ───────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
API_BASE_URL_INTERNAL=http://catalog-api:3001/api

# ── Admin (Next.js + next-auth) ─────────────────────────────
ADMIN_PORT=3002
AUTH_SECRET=dev-secret-cambia-esto-por-uno-aleatorio-largo
AUTH_KEYCLOAK_ID=optimus-admin
AUTH_KEYCLOAK_SECRET=optimus-admin-secret
