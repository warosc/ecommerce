// Prisma schema — microservicio Pedidos (Óptica Optimus)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PLACED
}

enum OrderChannel {
  WEB
  POS
}

enum PaymentMethod {
  CASH
  CARD
}

model Order {
  id            String         @id @default(uuid())
  status        OrderStatus    @default(PLACED)
  channel       OrderChannel   @default(WEB)
  paymentMethod PaymentMethod?
  customerName  String
  customerEmail String
  customerPhone String?
  /// Tipo de lente elegido en el checkout (SIN_GRADUACION|MONOFOCAL|PROGRESIVO|OCUPACIONAL). Nulo si no aplica.
  lensType      String?
  /// Fórmula/receta que el cliente indicó al comprar (texto libre). Nulo si no aplica.
  prescriptionNote String?
  totalAmount   Int
  currency      String         @default("GTQ")
  createdAt     DateTime       @default(now())
  lines         OrderLine[]

  @@map("orders")
}

model OrderLine {
  id              String @id @default(uuid())
  orderId         String
  sku             String
  name            String
  unitPriceAmount Int
  quantity        Int
  order           Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_lines")
}
